# =============================================================================
# CR YAPIM — cryapim.com
# .env.local olarak kopyala ve gerçek değerleri doldur. Bu dosya repo'ya
# commit edilebilir; .env.local edilmez.
# =============================================================================

# -----------------------------------------------------------------------------
# Sanrı (Caelinus AI rüya katmanı)
# -----------------------------------------------------------------------------
# OpenAI API key. Set edilmezse Sanrı 33 elle yazılmış fallback yanıttan
# birini deterministik seçer — yine karakterde konuşur, ama statik.
OPENAI_API_KEY=

# Hangi OpenAI modelini kullansın. Varsayılan gpt-4o-mini (hızlı + ucuz +
# kısa edebî yanıtlar için yeterli). gpt-4o veya gpt-4.1 daha derin verir
# ama maliyet artar.
SANRI_MODEL=gpt-4o-mini

# Panel başlığında "canlı" rozetini gösterip göstermeyeceği (NEXT_PUBLIC_
# olmak zorunda — client'a sızmalı). 1 = göster, boş/0 = gösterme.
NEXT_PUBLIC_SANRI_LIVE=1

# -----------------------------------------------------------------------------
# Perde topluluk arşivi (Vercel KV — Upstash Redis)
# -----------------------------------------------------------------------------
# Vercel Dashboard → Storage → Marketplace → Upstash for Redis kur. Otomatik
# eklenir. Lokal için: vercel env pull .env.local
#
# Yoksa: cache off, /perde landing'deki "Toplulukça yorumlananlar" bölümü
# gizlenir, her Perde sorusu OpenAI'a gider.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# -----------------------------------------------------------------------------
# Perde poster + backdrop (TMDB — The Movie Database)
# -----------------------------------------------------------------------------
# https://www.themoviedb.org/settings/api → "Request an API Key" → Developer
# Onay anında. "API Read Access Token (v4 auth)" — uzun JWT (eyJ...)
#
# Yoksa: kart kapaklarında ◧/◇ sembol fallback'i, detay sayfasında poster ve
# backdrop yok. Yorum içeriği etkilenmez.
TMDB_API_TOKEN=

# -----------------------------------------------------------------------------
# Stüdyo randevu — "Randevu Al" butonu hedefi
# -----------------------------------------------------------------------------
# Öncelik sırası:
#   1. NEXT_PUBLIC_BOOKING_CALENDLY varsa → Calendly linkine gider (yeni sekme)
#   2. NEXT_PUBLIC_BOOKING_WHATSAPP varsa → wa.me/{numara}?text=hazır mesaj
#   3. Hiçbiri yoksa → /iletisim formuna düşer
#
# WhatsApp numarası uluslararası formatta: +90 555 555 55 55 → 905555555555
# Boşluk/+ otomatik temizlenir; her iki format da çalışır.
NEXT_PUBLIC_BOOKING_WHATSAPP=
NEXT_PUBLIC_BOOKING_CALENDLY=
